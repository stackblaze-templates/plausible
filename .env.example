# Plausible environment configuration
# Copy this file to .env and fill in real values before starting.
# NEVER commit .env to version control.

# Required: Full public URL of your Plausible instance (no trailing slash)
BASE_URL=https://plausible.example.com

# Required: Secret key used to sign sessions and tokens.
# Generate with: openssl rand -base64 48
SECRET_KEY_BASE=REPLACE_WITH_STRONG_RANDOM_SECRET

# Required: PostgreSQL connection string
DATABASE_URL=postgresql://plausible:REPLACE_DB_PASSWORD@db:5432/plausible

# Optional: SMTP configuration for email registration / password reset
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASSWORD=REPLACE_SMTP_PASSWORD
# MAILER_EMAIL=hello@example.com
